<!DOCTYPE html>
<html data-theme="retro" lang="en">
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AWS Command Dashboard</title>
  <link rel="stylesheet" href="output.css" type="text/css">
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@700;800&display=swap"
    rel="stylesheet" />
  <style>
    body {
      font-family: 'Share Tech Mono', monospace;
    }

    .nav-title {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
    }

    .mockup-code {
      min-height: 340px;
      max-height: 480px;
      overflow-y: auto;
    }

    .mockup-code pre[data-prefix]::before {
      font-family: 'Share Tech Mono', monospace;
    }

    .cmd-meta {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.75rem;
      opacity: 0.6;
    }
  </style>
</head>

<body class="min-h-screen flex flex-col">

  <!-- NAV -->
  <nav class="navbar border-b-2 border-base-content justify-center">
    <span class="nav-title text-2xl tracking-tight">⬡ PANEL DE CONTROL AWS </span>
  </nav>

  <!-- MAIN BODY -->
  <main class="flex-1 flex flex-col items-center justify-start py-12 px-4 gap-8">

    <!-- COMMAND BUTTONS -->
    <section class="w-full max-w-2xl">
      <p class="cmd-meta mb-3">// SELECT A COMMAND TO EXECUTE</p>
      <div class="flex flex-wrap gap-3">
        <button class="btn btn-primary">Deploy App</button>
        <button class="btn btn-secondary">Restart Service</button>
        <button class="btn btn-accent">Run Health Check</button>
        <button class="btn">List Buckets</button>
        <button class="btn">List DynamoDB Tables</button>
        <button class="btn btn-error">Create DynamoDB Table</button>
      </div>
    </section>

    <!-- OUTPUT TERMINAL -->
    <section class="w-full max-w-2xl">
      <div class="flex items-center justify-between mb-3">
        <p class="cmd-meta">// CLOUDWATCH LOG </p>
      </div>

      <div class="mockup-code w-full">
        <pre data-prefix="$"><code>Esperando Comando...</code></pre>
        <pre data-prefix=">" class="text-warning"><code>Sin logs por el momento...</code></pre>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer footer-center border-t-2 border-base-content p-6 gap-1">
    <p class="cmd-meta">AWS CONTROL PANEL — internal tooling</p>
    <p class="cmd-meta">logs streamed via cloudwatch · region: us-east-1</p>
  </footer>

</body>
<script>
  const outputMain = document.querySelector('.mockup-code pre:first-child code')
  const outputSecondary = document.querySelector('.mockup-code pre:last-child code')

  function setOutput(main, secondary = "") {
    outputMain.textContent = main
    outputSecondary.textContent = secondary
  }

  //ADAPTADORES AXIOS

  async function listBuckets() {
    try {
      setOutput("Ejecutando: S3 List...", "")
      const res = await axios.get('/s3/list')
      setOutput("Buckets obtenidos:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  async function createBucket() {
    try {
      setOutput("Creando bucket...", "")
      const res = await axios.get('/s3/create')
      setOutput("Bucket creado:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  async function listEC2() {
    try {
      setOutput("Listando EC2...", "")
      const res = await axios.get('/ec2/list')
      setOutput("Instancias:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  async function createEC2() {
    try {
      setOutput("Creando instancia EC2...", "")
      const res = await axios.get('/ec2/create')
      setOutput("Instancia creada:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  async function listDynamo() {
    try {
      setOutput("Listando tablas Dynamo...", "")
      const res = await axios.get('/dynamo/list')
      setOutput("Tablas:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  async function createDynamo() {
    try {
      setOutput("Creando tabla Dynamo...", "")
      const res = await axios.get('/dynamo/create')
      setOutput("Tabla creada:", JSON.stringify(res.data, null, 2))
    } catch (err) {
      setOutput("Error", err.message)
    }
  }

  //EVENTOS A BOTONES

  const buttons = document.querySelectorAll('button')

  buttons[0].onclick = createEC2         // Deploy App
  buttons[1].onclick = () => location.reload() // Restart (placeholder)
  buttons[2].onclick = listEC2           // Health Check
  buttons[3].onclick = listBuckets       // Fetch Logs
  buttons[4].onclick = listDynamo        // List DynamoDB Tables
  buttons[5].onclick = createDynamo      // Create DynamoDB Table
</script>
</html>